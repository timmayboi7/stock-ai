# TKC Studio Stock AI — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Alpaca Paper Trading ───────────────────────────────────────────────
# Free account at https://alpaca.markets — use Paper Trading keys only
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI Backend ────────────────────────────────────────────────────────
# Options: ollama (free/local), anthropic (cloud), openai (cloud)
AI_BACKEND=ollama

# Ollama (free, runs locally — install from https://ollama.com)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434

# Anthropic Claude (optional cloud AI — https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT (optional cloud AI — https://platform.openai.com)
# OPENAI_API_KEY=sk-...

# ── Remote Logging (optional) ─────────────────────────────────────────
# Pushes trade logs to a private GitHub repo after each cycle
# GITHUB_TOKEN=github_pat_...
# GITHUB_REPO=yourusername/tkc-trader-logs
# MACHINE_ID=primary
